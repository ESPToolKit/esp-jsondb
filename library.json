{
  "name": "ESPJsonDB",
  "version": "2.0.0",
  "description": "Embedded MessagePack-backed document database for ESP32 with durable metadata, load policies, snapshots, and async file storage.",
  "keywords": [
    "esp32",
    "arduino",
    "json",
    "database",
    "nosql",
    "document",
    "littlefs",
    "storage",
    "mongodb-like"
  ],
  "homepage": "https://github.com/ESPToolKit/esp-jsondb",
  "repository": {
    "type": "git",
    "url": "https://github.com/ESPToolKit/esp-jsondb.git"
  },
  "license": "MIT",
  "authors": [
    {
      "name": "zekageri"
    }
  ],
  "frameworks": ["arduino"],
  "platforms": ["espressif32"],
  "dependencies": [
    {
      "name": "ArduinoJson",
      "owner": "bblanchon",
      "version": ">=6.21.0"
    },
    {
      "name": "StreamUtils",
      "owner": "bblanchon",
      "version": ">=1.7.0"
    },
    {
      "name": "ESPBufferManager",
      "version": "https://github.com/ESPToolKit/esp-buffer-manager.git"
    }
  ],
  "headers": ["ESPJsonDB.h", "ESPJsonDBCompressor.h"],
  "build": {
    "flags": [
      "-std=gnu++17",
      "-fno-exceptions"
    ]
  }
}
